<footer class="site-footer">
  <div class="footer-top">
    <div class="footer-col footer-brand">
      <img src="/assets/logo-cindy.png" alt="{{ site.name }}" class="footer-logo">
      <p class="footer-tagline">Mieux comprendre votre chat, pour mieux cohabiter. Accompagnement bienveillant fondé sur l'éthologie féline.</p>
    </div>

    <div class="footer-col">
      <h3 class="footer-heading">Contact</h3>
      <a href="mailto:{{ site.email }}" class="footer-link"><i class="fa-solid fa-envelope" aria-hidden="true"></i> {{ site.email }}</a>
      <a href="tel:{{ site.phone | replace(' ', '') }}" class="footer-link"><i class="fa-solid fa-phone" aria-hidden="true"></i> {{ site.phone }}</a>
      <p class="footer-link"><i class="fa-solid fa-location-dot" aria-hidden="true"></i> {{ site.address }}</p>
      <a href="/contact/" class="button button-sm footer-cta">{{ site.ctaLabel }}</a>
    </div>
  </div>

  <p class="page-signature">{{ site.pageSignature }}</p>

  <div class="footer-bottom">
    <p class="footer-copy">&copy; {{ "" | year }} {{ site.name }}. Tous droits réservés.</p>
    <nav class="footer-legal" aria-label="Liens légaux">
      {% for item in site.footerNav %}
      <a href="{{ item.url }}" class="footer-legal-link{% if page.url == item.url %} active{% endif %}">{{ item.label }}</a>
      {% endfor %}
    </nav>
  </div>
</footer>
